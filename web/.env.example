# Base URL of the Senpai FastAPI bridge (senpai/api/server.py).
# Defaults to http://localhost:8000 if unset. For a Vercel deploy, point this at
# wherever the API is hosted; if the API is unreachable the UI falls back to the
# committed seed snapshot (lib/fixtures.ts) so the demo never breaks.
NEXT_PUBLIC_API_BASE=http://localhost:8000
